rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default rule: Allow anyone to READ public content
    // and only authenticated ADMINS to WRITE (after login)
    match /{document=**} {
      // READ: Public access for visitors
      allow read: if true;
      
      // WRITE: Only for the authenticated admin users
      // (Uses the Firebase Auth implementation we just set up)
      allow write: if request.auth != null;
    }
  }
}
